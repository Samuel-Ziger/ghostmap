# ---------- GhostMap env ----------
# Copie para .env e ajuste.

# Core
GHOSTMAP_ENV=dev
GHOSTMAP_SECRET=replace-with-openssl-rand-hex-32

# Databases
POSTGRES_PASSWORD=ghostmap
NEO4J_PASSWORD=ghostmap_neo4j

# AI providers (deixe vazio para desabilitar o provider)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local). Mude se rodar fora do host.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Defaults opcionais
GHOSTMAP_DEFAULT_PROJECT_ID=
NODE_ENV=development
